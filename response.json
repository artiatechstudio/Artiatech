                                   "content":  {
                                                   "type":  "html",
                                                   "$t":  "\u003chtml\u003e\n\u003chead\u003e\n\u003cmeta charset=\"UTF-8\"\u003e\n\u003ctitle\u003eCareingo | تواصل تحدى تطور\u003c/title\u003e\n\u003c/head\u003e\n\u003cstyle\u003e\n\nbody{\n  \nfont-family: Arial;\nbackground:#f4f7fb;\nmargin:0;\npadding:0;\n}\n\n.container{\nmax-width:1200px;\nmargin:auto;\nbackground:white;\npadding:40px;\nbox-shadow:0 0 20px rgba(0,0,0,0.08);\n}\n\n.header{\ntext-align:center;\nmargin-bottom:40px;\n}\n\n.logo{\nfont-size:36px;\nfont-weight:bold;\ncolor:#2c3e50;\n}\n\n.slogan{\nfont-size:18px;\ncolor:#777;\nmargin-top:8px;\n}\n\n.section-title{\nmargin-top:40px;\nfont-size:26px;\ncolor:#2c3e50;\n}\n\np{\nfont-size:18px;\nline-height:1.9;\ncolor:#444;\n}\n\n.feature{\nmargin-top:20px;\nline-height:1.8;\nfont-size:18px;\n}\n\n.try-btn{\nmargin-top:40px;\nbackground:#27ae60;\ncolor:white;\npadding:18px 40px;\nfont-size:22px;\nborder:none;\nborder-radius:10px;\ncursor:pointer;\n}\n\n.try-btn:hover{\nbackground:#1e8449;\n}\n\n.counter{\nmargin-top:40px;\ntext-align:center;\n}\n\n.counter-number{\nfont-size:45px;\nfont-weight:bold;\ncolor:#2c3e50;\n}\n\n  /* حاوية الصور الرئيسية */\n  .custom-image-gallery {\n    display: flex;          /* صف العناصر بجانب بعضها */\n    overflow-x: auto;       /* تفعيل التمرير الأفقي */\n    white-space: nowrap;    /* منع التفاف الصور لسطر جديد */\n    gap: 12px;              /* مسافة بين الصور */\n    padding: 15px;\n    background: #f9f9f9;    /* لون خلفية خفيف */\n    border-radius: 10px;\n      /* تنحيف شريط التمرير للمتصفحات الحديثة */\n  }\n\n  /* تنسيق كل رابط/صورة */\n  .custom-image-gallery .separator {\n    flex: 0 0 auto;         /* منع انكماش الصور */\n    margin: 0 !important;   /* إلغاء الهوامش الافتراضية */\n  }\n\n  .custom-image-gallery img {\n    height: 350px;          /* حجم الصور (صغيرة نسبياً) */\n    width: auto;            /* الحفاظ على التناسب */\n    border-radius: 5px;     /* زوايا منحنية */\n    transition: transform 0.3s; /* تأثير عند مرور الماوس */\n    display: block;\n  }\n\n  .custom-image-gallery img:hover {\n    transform: scale(1.05); /* تكبير بسيط عند التأشير */\n  }\n  .install-top{\nposition:fixed;\ntop:0;\nwidth:100%;\nbackground:#27ae60;\ncolor:white;\ntext-align:center;\npadding:15px;\nfont-size:20px;\ncursor:pointer;\nz-index:9999;\n}\n\n.apk-btn{\nmargin-top:20px;\nbackground:#2980b9;\ncolor:white;\npadding:18px 40px;\nfont-size:22px;\nborder:none;\nborder-radius:10px;\ncursor:pointer;\n}\n\n.apk-btn:hover{\nbackground:#1f6694;\n  }\n\u003c/style\u003e\n\n\n\n\n\n\u003cbody\u003e\n\n\u003cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEi4KGSJx8kHwsN7bj8_UVsPiZ4QSY6zPZIEwg68qSlFWeHgMQKMp34hyn2jSz01v63k1j0j9k4KpIWIChbFJcGz7YZ8PUVBZSlB_ehXHfAJRaoYs_-gJ0MCW8BNasdwzD5-lJZhkV9dMrLfVwR0KGmmxfMZa68AnrfxK6_wNJ_kA21sBLTkxZJS5Iea8es\" style=\"margin-left: 1em; margin-right: 1em;\"\u003e\u003cimg alt=\"\" data-original-height=\"207\" data-original-width=\"216\" height=\"240\" src=\"https://blogger.googleusercontent.com/img/a/AVvXsEi4KGSJx8kHwsN7bj8_UVsPiZ4QSY6zPZIEwg68qSlFWeHgMQKMp34hyn2jSz01v63k1j0j9k4KpIWIChbFJcGz7YZ8PUVBZSlB_ehXHfAJRaoYs_-gJ0MCW8BNasdwzD5-lJZhkV9dMrLfVwR0KGmmxfMZa68AnrfxK6_wNJ_kA21sBLTkxZJS5Iea8es\" width=\"250\" /\u003e\u003c/a\u003e\u003c/div\u003e\u003cbr /\u003e\n\u003cdiv class=\"container\"\u003e\n\n\u003cdiv class=\"header\"\u003e\n\u003cdiv class=\"logo\"\u003eCareingo\u003c/div\u003e\n\u003cdiv class=\"slogan\"\u003eتواصل • تحدى • تطور\u003c/div\u003e\n\u003c/div\u003e\n\u003cdiv class=\"install-top\" onclick=\"scrollToAPK()\"\u003e\n📲 ثبت Careingo الآن\n  \u003c/div\u003e\n\u003cp\u003e\n\nكارينجو هو منصة تفاعلية حديثة تهدف إلى تحويل رحلة تطوير الذات من مجرد أفكار\nنظرية إلى تجربة عملية يومية مليئة بالتحديات والتحفيز والتفاعل الاجتماعي.\n\nيعتمد التطبيق على فلسفة التحسن التدريجي (Kaizen)، والتي تقوم على فكرة أن\nالتغييرات الصغيرة المتكررة يمكن أن تصنع تحولات كبيرة في حياة الإنسان\nعلى المدى الطويل.\n\n  \n  \nمن خلال نظام متكامل من التحديات اليومية والإنجازات والمنافسة\nوالمجتمع التفاعلي، يساعدك كارينجو على بناء عادات إيجابية\nتدفعك تدريجياً نحو أفضل نسخة من نفسك.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e🚀 نظام التحديات اليومية\u003c/div\u003e\n\n\u003cp\u003e\n\nيقدم كارينجو تجربة فريدة تعتمد على 120 مرحلة متدرجة موزعة على أربعة مسارات\nأساسية في حياة الإنسان:\n\nاللياقة البدنية، التغذية الصحية، السلوك النفسي، والتعلم المستمر.\n\nكل مرحلة تمثل تحدياً عملياً بسيطاً يمكنك تنفيذه في حياتك اليومية،\nلكن قوة النظام تكمن في الاستمرارية.\n\nلمنع المستخدم من محاولة إنهاء جميع المهام بسرعة أو ما يعرف بـ \"حرق المهام\"،\nيحتوي التطبيق على مؤقت ذكي يمنع فتح أكثر من مرحلة واحدة في نفس المسار\nخلال اليوم الواحد.\n\nبعد إكمال التحدي يبدأ مؤقت العد التنازلي حتى منتصف الليل،\nوعندها فقط يتم فتح المرحلة التالية.\n\nهذا النظام يضمن أن عملية التغيير تتم بشكل تدريجي ومستدام،\nمما يجعل العادات الجديدة أكثر ثباتاً في حياتك.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e🧠 نظام النقاط والتحفيز الذكي\u003c/div\u003e\n\n\u003cp\u003e\n\nكل إنجاز تقوم به داخل التطبيق يتم مكافأتك عليه بنظام نقاط\nمصمم بعناية ليحفزك على الاستمرار.\n\nتحصل على نقاط أساسية عند إكمال أي تحدٍ،\nلكن هناك أيضاً مكافآت إضافية تعتمد على توقيت الإنجاز.\n\nكلما أنجزت المهام في وقت مبكر من اليوم،\nحصلت على نقاط إضافية فيما يعرف بنظام \"المبادر المبكر\".\n\nكما يمكنك إنشاء مهام إضافية خاصة بك داخل التطبيق،\nمثل قراءة كتاب أو تعلم مهارة جديدة،\nوعند إكمال هذه المهام تحصل أيضاً على نقاط إضافية.\n\nبهذا يصبح التطبيق مرناً وقادراً على التكيف مع أهدافك الشخصية.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e🏆 لوحة المتصدرين وجدار العار\u003c/div\u003e\n\n\u003cp\u003e\n\nكارينجو ليس مجرد تطبيق فردي، بل تجربة تنافسية ممتعة.\n\nتسمح لوحة المتصدرين بمقارنة تقدمك مع بقية المستخدمين\nبناءً على مستوى الحماسة والنقاط التي حققتها.\n\nكلما حافظت على التزامك اليومي وواصلت تنفيذ التحديات،\nارتفع ترتيبك بين المستخدمين.\n\nلكن التحدي لا يقتصر على النجاح فقط.\n\nهناك أيضاً ما يسمى \"جدار العار\"،\nوهو قسم يظهر فيه المستخدمون الذين كسروا سلسلة الحماسة\nوتوقفوا عن تنفيذ التحديات اليومية.\n\nهذا العنصر يضيف مستوى إضافياً من التحدي والتحفيز\nويشجع المستخدمين على عدم الاستسلام.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e💬 المجتمع التفاعلي\u003c/div\u003e\n\n\u003cp\u003e\n\nيوفر كارينجو مجتمعاً اجتماعياً كاملاً داخل التطبيق.\n\nيمكنك التواصل مع المستخدمين الآخرين بعدة طرق،\nمن بينها الدردشة الخاصة التي تسمح لك بإرسال الرسائل\nوالتواصل المباشر مع أي شخص داخل المنصة.\n\nكما يحتوي التطبيق على جدار اجتماعي عام\nيمكن للمستخدمين نشر منشورات عليه\nحول تقدمهم أو تجاربهم أو أفكارهم.\n\nيمكن لبقية المستخدمين التفاعل مع هذه المنشورات\nعن طريق التعليق أو الإعجاب باستخدام زر \"Like\".\n\nهذا المجتمع التفاعلي يجعل رحلة تطوير الذات\nأكثر متعة ودعماً وتحفيزاً.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e🏅 نظام الأوسمة والإنجازات\u003c/div\u003e\n\n\u003cp\u003e\n\nيكافئ كارينجو المستخدمين بنظام أوسمة متكامل\nيحصلون عليه عند تحقيق إنجازات مختلفة.\n\nيمكنك الحصول على الأوسمة عند إكمال عدد معين من التحديات،\nأو الحفاظ على سلسلة حماسة طويلة،\nأو تحقيق إنجازات خاصة داخل المسارات المختلفة.\n\nيتم عرض هذه الأوسمة في ملفك الشخصي العام\nليتمكن المستخدمون الآخرون من رؤية إنجازاتك.\n\nوبذلك يصبح ملفك الشخصي انعكاساً حقيقياً\nلمدى التزامك وتقدمك داخل المنصة.\n\n\u003c/p\u003e\n\n\u003cdiv class=\"section-title\"\u003e👑 وضع البريميوم\u003c/div\u003e\n\n\u003cp\u003e\n\nيقدم كارينجو تجربة قوية في النسخة المجانية،\nلكن للمستخدمين الأكثر جدية في تطوير أنفسهم\nيوجد وضع البريميوم الذي يفتح ميزات إضافية.\n\nمن بين هذه الميزات ميزة تجميد الحماسة\nالتي تسمح لك بالحفاظ على سلسلة تقدمك\nفي حال واجهتك ظروف طارئة في أحد الأيام.\n\nكما يوفر البريميوم أدوات إضافية\nتجعل تجربة التحفيز داخل التطبيق أكثر قوة ومرونة.\n\n\u003c/p\u003e\n  \u003cdiv class=\"section-title\"\u003e⚔️ نظام المباريات والمحاكمة المجتمعية\u003c/div\u003e\n\n\u003cp\u003e\nيقدم كارينجو ميزة المباريات بين لاعبين اثنين حيث يمكن للمستخدمين\nالتنافس في تنفيذ التحديات بشكل مباشر.\n\u003c/p\u003e\n\n\u003cp\u003e\nبعد انتهاء المباراة يتم عرض النتائج على المجتمع\nليقوم المستخدمون بدور المحكمين عبر نظام محاكمة مجتمعية\nيحدد الفائز بشكل عادل.\n  \u003c/p\u003e\n\n\u003cdiv style=\"text-align: center;\"\u003e\n\n  \u003cdiv id=\"apkSection\" style=\"margin-top: 20px; text-align: center;\"\u003e\n\u003cbutton class=\"apk-btn\" onclick=\"downloadAPK()\"\u003e\n⬇️ تحميل نسخة APK\n\u003c/button\u003e\n  \u003c/div\u003e\n  \n\u003cbutton class=\"try-btn\" onclick=\"openApp()\"\u003e\n🚀 جرب التطبيق الآن\n\u003c/button\u003e\n\n\u003c/div\u003e\n\n\u003cdiv class=\"counter\"\u003e\n\n\u003cp\u003eعدد المستخدمين الذين جربوا التطبيق\u003c/p\u003e\n\n\u003cdiv class=\"counter-number\" id=\"downloadCount\"\u003e0\u003c/div\u003e\n\n\u003c/div\u003e\n\n\u003c/div\u003e\n\n  \u003cdiv class=\"custom-image-gallery\"\u003e\n  \n  \u003c!-- صورة 2 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEga0tLO1QiUCdQxl7H35oBhSPEVz1-VjU31ASpkgHZLJt0iD-yFvzEHm-yohcDyVyaGal1iATA6mPjx9Rb9-V-HYouXPG_O4l5D7M7XmOUFqsyN5KfZZWs57qFACXRbmAAvV_UKha1lO8Jkz0de6t3JeC5O8nj1l41r8Ad5M4bGtXZ3dYrA_er606ttV4k\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEga0tLO1QiUCdQxl7H35oBhSPEVz1-VjU31ASpkgHZLJt0iD-yFvzEHm-yohcDyVyaGal1iATA6mPjx9Rb9-V-HYouXPG_O4l5D7M7XmOUFqsyN5KfZZWs57qFACXRbmAAvV_UKha1lO8Jkz0de6t3JeC5O8nj1l41r8Ad5M4bGtXZ3dYrA_er606ttV4k\" /\u003e\u003c/a\u003e\u003c/div\u003e\n  \u003c!-- صورة 3 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEix6MN7g8YeJs-uYrxi3MC_9dnzhBLoEoKWxWcF3Ws7pOFc9s42vnE9k3ZqSmeLb4Xm_ZczkkwYpSljcQl6OeDFJlVvo3VLySkbbEjaz6OTv9a429iTFtJYICLLo6JQCUYdBrrUIME7HoRk5zhnWy_TOS_GKCrUKLkOpQ8eSKXI8Md2hpl2BcxjDJDhhfo\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEix6MN7g8YeJs-uYrxi3MC_9dnzhBLoEoKWxWcF3Ws7pOFc9s42vnE9k3ZqSmeLb4Xm_ZczkkwYpSljcQl6OeDFJlVvo3VLySkbbEjaz6OTv9a429iTFtJYICL