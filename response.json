ة 7 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEichWyWWJE-VDtANGl1pfG3gNjZ2oDbodQ9Q-4kGi1NXQvSGy6tyqtHd1x3zfSh0xOXYiWAfRhAf8XOaprI4jzz8HR9w4qkyZzexeCI7-IUSylhbXU5F_umxTIK6cNwR6OvqSeOOrUPqgqby21MJUw_EHSdKtkL6DbPDUbHz8fWwTfqDtyM0THeMz_xdGE\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEichWyWWJE-VDtANGl1pfG3gNjZ2oDbodQ9Q-4kGi1NXQvSGy6tyqtHd1x3zfSh0xOXYiWAfRhAf8XOaprI4jzz8HR9w4qkyZzexeCI7-IUSylhbXU5F_umxTIK6cNwR6OvqSeOOrUPqgqby21MJUw_EHSdKtkL6DbPDUbHz8fWwTfqDtyM0THeMz_xdGE\" /\u003e\u003c/a\u003e\u003c/div\u003e\n  \u003c!-- صورة 8 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEiqLgL2faabuz-ECcCLcwt5bUaOMlgmTUx9F58QubVS7pGaDfwZ5GKBMwycmw5AHYgKL8QaGYxawXyZfEy4MdjXarwupde4ibIBwG0ym2brmx4X3c_fXWCWHKa-QYoSc8T7EfMpsmOcjFCjMEZdGyX_9rRR83aWUhIaLmtq0Be71Fdo0FKwSzscw9fVoDc\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEiqLgL2faabuz-ECcCLcwt5bUaOMlgmTUx9F58QubVS7pGaDfwZ5GKBMwycmw5AHYgKL8QaGYxawXyZfEy4MdjXarwupde4ibIBwG0ym2brmx4X3c_fXWCWHKa-QYoSc8T7EfMpsmOcjFCjMEZdGyX_9rRR83aWUhIaLmtq0Be71Fdo0FKwSzscw9fVoDc\" /\u003e\u003c/a\u003e\u003c/div\u003e\n  \u003c!-- صورة 9 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEiDJQy15G7WfRt8ACxIB9T6HR6coGlOY9DNokDsaGtbBAYon5mv0v6RaFZxqyN6SD_t1aPIe1BLJCVmBiwWuBBOEAFqgYM7N8LCjkF7OeLKbvl1RQS5iMrx0ezrPaK-d30JJ_rN0f7lW6vvnC4JjIfZzk7Nh4iWDplb21VxnNcB8Jht4bEWoYRWiTj1pHA\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEiDJQy15G7WfRt8ACxIB9T6HR6coGlOY9DNokDsaGtbBAYon5mv0v6RaFZxqyN6SD_t1aPIe1BLJCVmBiwWuBBOEAFqgYM7N8LCjkF7OeLKbvl1RQS5iMrx0ezrPaK-d30JJ_rN0f7lW6vvnC4JjIfZzk7Nh4iWDplb21VxnNcB8Jht4bEWoYRWiTj1pHA\" /\u003e\u003c/a\u003e\u003c/div\u003e\n  \u003c!-- صورة 10 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEiTzwrWOU_vqjbAZYRUouQGdcCHy-OBAzkY8KUs-P5u1jVxfud85JaDZx8lzwlXH2Nt7-zuXDnJmOz9xNF76uuOsf0EvbP-7IRrUIvOR6XnJoavUnjncPnBrkUvdZXAFciYke4IrlkZEUljRn9qSug2ODtN5sIPrcQSIPl_InB2K5rFtXJbbVzpJtRsX9A\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEiTzwrWOU_vqjbAZYRUouQGdcCHy-OBAzkY8KUs-P5u1jVxfud85JaDZx8lzwlXH2Nt7-zuXDnJmOz9xNF76uuOsf0EvbP-7IRrUIvOR6XnJoavUnjncPnBrkUvdZXAFciYke4IrlkZEUljRn9qSug2ODtN5sIPrcQSIPl_InB2K5rFtXJbbVzpJtRsX9A\" /\u003e\u003c/a\u003e\u003c/div\u003e\n  \u003c!-- صورة 11 --\u003e\n  \u003cdiv class=\"separator\"\u003e\u003ca href=\"https://blogger.googleusercontent.com/img/a/AVvXsEhuDT9apdCYtuyjkuRU6iYnUZsU8O4Yt6DEoBsqLO-imPyqrfLO3IRcQObFUelbi9xHcyLE_Kc7botuv4_1VN52aekm_xNBJoJ4oFMmq_42jjhEZE8XxhSIcUmUrRZHJtqpc5lqLedGV6qCFZLDvOTeQ6hiGf5wBfz6cVu3NfeY__VSEkXqYoB-X-6AUDk\"\u003e\u003cimg src=\"https://blogger.googleusercontent.com/img/a/AVvXsEhuDT9apdCYtuyjkuRU6iYnUZsU8O4Yt6DEoBsqLO-imPyqrfLO3IRcQObFUelbi9xHcyLE_Kc7botuv4_1VN52aekm_xNBJoJ4oFMmq_42jjhEZE8XxhSIcUmUrRZHJtqpc5lqLedGV6qCFZLDvOTeQ6hiGf5wBfz6cVu3NfeY__VSEkXqYoB-X-6AUDk\" /\u003e\u003c/a\u003e\u003c/div\u003e\n\u003c/div\u003e\n  \u003cdiv style=\"font-family: Arial; margin-top: 40px; margin: auto; max-width: 900px;\"\u003e\n\n\u003ch2 style=\"text-align: center;\"\u003e📲 كيفية تثبيت تطبيق Careingo\u003c/h2\u003e\n\n\u003cp style=\"font-size: 18px; text-align: center;\"\u003e\nبما أن كارينجو يعمل كتطبيق ويب ، يمكنك شغيله على جهازك بسهولة\nليعمل مثل من متصفحك كاي تطبيق عادي على هاتفك أو حاسوبك.\n\u003c/p\u003e\n\n\u003chr /\u003e\n\n\u003c!-- ANDROID --\u003e\n\n\u003ch3\u003e🤖 التثبيت على هواتف الأندرويد\u003c/h3\u003e\n\n\u003col style=\"font-size: 18px; line-height: 2;\"\u003e\n\n\u003cli\u003e\nاضغط على رابط التطبيق الموجود أسفل الصفحة\n\u003c/li\u003e\n\n\u003cli\u003e\nعند فتح الموقع في متصفح \n\u003cb\u003eGoogle Chrome\u003c/b\u003e\nاضغط على زر القائمة\n\u003cspan style=\"font-size: 20px;\"\u003e⋮\u003c/span\u003e\nفي أعلى الشاشة\n\u003c/li\u003e\n\n\u003cli\u003e\nاختر الخيار\n\u003cb\u003eإضافة إلى الشاشة الرئيسية\u003c/b\u003e\n\u003c/li\u003e\n\n\u003cli\u003e\nاضغط على زر \u003cb\u003eإضافة\u003c/b\u003e\nوسيظهر تطبيق Careingo على الشاشة الرئيسية لهاتفك\n\u003c/li\u003e\n\n\u003c/ol\u003e\n    \nيمكنك بسهولة ايضا تثبيت نسخة apk من الزر اعلاه\n\n\n\u003chr /\u003e\n\n\u003c!-- IOS --\u003e\n\n\u003ch3\u003e🍎 التثبيت على هواتف iPhone و iPad\u003c/h3\u003e\n\n\u003col style=\"font-size: 18px; line-height: 2;\"\u003e\n\n\u003cli\u003e\nافتح رابط التطبيق باستخدام متصفح\n\u003cb\u003eSafari\u003c/b\u003e\n\u003c/li\u003e\n\n\u003cli\u003e\nاضغط على زر المشاركة\n\u003cspan style=\"font-size: 20px;\"\u003e⬆️\u003c/span\u003e\nالموجود أسفل الشاشة\n\u003c/li\u003e\n\n\u003cli\u003e\nقم بالتمرير للأسفل واختر\n\u003cb\u003eإضافة إلى الشاشة الرئيسية\u003c/b\u003e\n\u003c/li\u003e\n\n\u003cli\u003e\nاضغط على \u003cb\u003eإضافة\u003c/b\u003e\nوسيظهر التطبيق كأيقونة مستقلة على جهازك\n\u003c/li\u003e\n\n\u003c/ol\u003e\n\n\u003chr /\u003e\n\n\u003cp style=\"font-size: 18px; margin-top: 30px; text-align: center;\"\u003e\nبعد تثبيت التطبيق ستتمكن من استخدامه بسهولة\nمثل أي تطبيق آخر على جهازك.\n\u003c/p\u003e\n\n\u003c/div\u003e\n\n\n\u003cscript src=\"https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js\"\u003e\u003c/script\u003e\n\u003cscript src=\"https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js\"\u003e\u003c/script\u003e\n\n\u003cscript\u003e\n\nconst firebaseConfig = {\ndatabaseURL:\"https://carengocount-default-rtdb.firebaseio.com/\"\n};\n\nfirebase.initializeApp(firebaseConfig);\n\nconst db = firebase.database();\n\nconst counterRef = db.ref(\"downloads/total\");\n\nconst visitorsRef = db.ref(\"visitors\");\n\ncounterRef.on(\"value\",(snapshot)=\u003e{\ndocument.getElementById(\"downloadCount\").innerText = snapshot.val() || 0;\n});\n\n\nfunction getDeviceID(){\n\nlet id = localStorage.getItem(\"careingoDeviceID\");\n\nif(!id){\n\nid = Math.random().toString(36).substring(2,12);\n\nlocalStorage.setItem(\"careingoDeviceID\",id);\n\n}\n\nreturn id;\n\n}\n\nfunction increaseCounter(callback){\n\nlet deviceID = getDeviceID();\n\nvisitorsRef.child(deviceID).once(\"value\",(snapshot)=\u003e{\n\nif(!snapshot.exists()){\n\nvisitorsRef.child(deviceID).set(true);\n\ncounterRef.transaction((current)=\u003e{\nreturn (current || 0) + 1;\n});\n\n}\n\nif(callback) callback();\n\n});\n\n}\n\nfunction openApp(){\nincreaseCounter(()=\u003e{\nwindow.open(\"https://careingo.onrender.com/\",\"_blank\");\n});\n}\n\nfunction downloadAPK(){\nincreaseCounter(()=\u003e{\nwindow.open(\n\"https://drive.google.com/uc?export=download\u0026id=1STpo6Oe4oLx5zpdlh69NectCdNLK3bem\",\n\"_blank\"\n);\n});\n}\n\nfunction scrollToAPK(){\ndocument.getElementById(\"apkSection\").scrollIntoView({behavior:\"smooth\"});\n}\n  \n\n\n\u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e\n"
                                               },
